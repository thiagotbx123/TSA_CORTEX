# KPI Pipeline — Environment Variables
# Copy this to ../.env and fill in real values

# Linear API key (required for refresh_linear_cache.py)
LINEAR_API_KEY=lin_api_your_key_here

# Google Drive upload (optional — only needed for upload_dashboard_drive.py)
# Uses OAuth flow via kpi_auth.py — see reauth_google.py for setup

# ngrok tunnel (optional — defaults shown)
# NGROK_URL=your-domain.ngrok-free.dev
# NGROK_BASIC_AUTH=user:password
# KPI_HTTP_PORT=8080

# Output directory (optional — defaults to ~/Downloads)
# KPI_OUTPUT_DIR=C:\Users\you\Downloads
